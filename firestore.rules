rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- USERS ---
    match /users/{userId} {
      // Any authenticated user can read their own doc (for login status check)
      // Admins can read ALL user docs (for user management page)
      allow read: if request.auth.uid == userId || isAdmin();
      
      // Users can create their own doc during signup
      allow create: if request.auth.uid == userId;
      
      // Only admins can update user docs (approve/reject)
      allow update: if isAdmin();
    }
    
    // --- SETTINGS ---
    match /settings/{doc} {
      // Any approved user can read settings
      allow read: if request.auth != null && isApproved();
      
      // Only admins can modify settings
      allow write: if isAdmin();
    }
    
    // --- PROJECTS ---
    match /projects/{pid} {
      // Any approved user can read projects
      allow read: if request.auth != null && isApproved();
      
      // Only approved users can create projects
      allow create: if request.auth != null && isApproved();
      
      // Owner or admin can update/delete
      allow update: if (request.auth.uid == resource.data.ownerUid || isAdmin()) && isApproved();
      allow delete: if (request.auth.uid == resource.data.ownerUid || isAdmin()) && isApproved();
      
      // --- SHEETS ---
      match /sheets/{sid} {
        allow read: if request.auth != null && isApproved();
        allow create: if request.auth != null && isApproved();
        allow update, delete: if (request.auth.uid == resource.data.ownerUid || isAdmin()) && isApproved();
      }
    }
    
    // --- HELPER FUNCTIONS ---
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    
    function isApproved() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // Admins are always approved. Regular users need status == "approved".
      return userData.role == "admin" || userData.status == "approved";
    }
  }
}
